# --- Fáze A (minimum provozu) ---
# 1) NODE_ENV=production při běhu (např. npm run start:prod)
# 2) HTTPS a reverse proxy u hostingu
# 3) Zálohy PostgreSQL — viz DEPLOY.md
# 4) CORS_ORIGIN = veřejná URL e-shopu
#
# --- Minimální provoz ---
# Připojení PostgreSQL (povinné pro katalog, objednávky, admin)
DATABASE_URL=
# Volitelný název PostgreSQL schématu (např. qhub), pokud chcete izolovat projekty
DATABASE_SCHEMA=

# Heslo pro přihlášení do administrace (#/admin) přes /api/login
ADMIN_PASSWORD=

# Port (Coolify / Docker / VPS)
PORT=3000

# Pro nasazení frontendu + API z jednoho procesu:
# npm run build && npm run start:prod
# (na Linuxu lze ekvivalentně: NODE_ENV=production npm start)

# --- Doporučené v produkci ---
# Pevný token pro Bearer u /api/admin/* (jinak se generuje při každém startu)
ADMIN_TOKEN=

# Povolené originy pro CORS (např. https://vas-obchod.cz nebo více oddělených čárkou).
# Pokud nevyplníte, server povolí všechny originy (vhodné jen pro vývoj / interní síť).
# CORS_ORIGIN=https://www.vas-obchod.cz

# Za reverse proxy (nginx, Traefik, Coolify) nechte zapnuté výchozí chování.
# Vypnutí: TRUST_PROXY=0
# TRUST_PROXY=1

# Omezení objednávky (volitelné)
# MAX_ORDER_LINES=80
# MAX_QTY_PER_LINE=99

# Volitelné: URL pro HTTP POST po vytvoření objednávky (JSON, např. Discord / Make / vlastní služba).
# ORDER_WEBHOOK_URL=https://example.com/hook

# --- E-mail po objednávce (volitelné; bez SMTP se nic neodesílá) ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=noreply@vas-obchod.cz
# MAIL_TO_SHOP=objednavky@vas-obchod.cz

# PostgreSQL SSL: u managed DB často sslmode=require v URL.
# Interní Docker bez SSL někdy: PGSSLMODE=disable
# PGSSLMODE=disable
